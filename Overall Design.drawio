        <mxCell id="L3nhJNZbnWeFIdARmH20-2" value="&lt;h1&gt;Jeff&#39;s Portfolio Website&lt;/h1&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;Website Type: Portfolio&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;Colour Theme: Blue&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;Requirements:&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;- Able to update easily&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;Pages:&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;- Landing DONE&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;- About Me DONE&lt;/p&gt;&lt;p style=&quot;line-height: 0px;&quot;&gt;- My Projects DONE&lt;/p&gt;&lt;p style=&quot;line-height: 0px;&quot;&gt;- My Certifications DONE&lt;/p&gt;&lt;p style=&quot;line-height: 0px;&quot;&gt;- My Education DONE&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;- My Experiences DONE&lt;/span&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;line-height: 0%;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;- Contact Me DONE&lt;/span&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
