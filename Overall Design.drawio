        <mxCell id="L3nhJNZbnWeFIdARmH20-9" value="Landing" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="290" width="380" height="230" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-10" value="Are you finding the right person to design, build and upkeep your website? If that&#39;s the case, your search ends here.&lt;br&gt;&lt;br&gt;Hi, I&#39;m Jeff, currently pursuing a diploma in Cybersecurity at Nanyang Polytechnic. Alongside my studies, I engage in personal coding projects during my leisure hours, typically aimed at resolving online challenges I encounter." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="L3nhJNZbnWeFIdARmH20-9">
          <mxGeometry x="15" y="50" width="350" height="160" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="L3nhJNZbnWeFIdARmH20-11" target="L3nhJNZbnWeFIdARmH20-15">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-11" value="About Me" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="550" width="380" height="380" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-12" value="My dream is to be able to work as a Software Engineer in one of the FAANG companies one day, at Silicon Valley. Although it is still too early to pursue this dream, I am making my steps to bring my dream closer to me.&lt;br&gt;&lt;br&gt;Since young, I had always been fascinated about the online world. Since primary school, I had joined ICT club, and it taught me about Game Design, Photography, Videography and Video Editing.&lt;br&gt;&lt;br&gt;After enrolling into Nanyang Polytechnic, that is the first time I get to touch with coding, and although coding is a very new thing to me, I immediately fell in love with it, like love at first sight.&lt;br&gt;&lt;br&gt;At first I still do not know what job should I pursue in the future, I just know that I want to work in IT industry. Under my friends influence I had got myself into pursuing diploma in Cybersecurity rather than Information Technology, after studying for Cybersecurity, although I still am, I had decided that being a Cybersecurity Expert, I want to be a Software Engineer in the future, and therefore here am, striving forward to become a Software Engineer in the future." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="L3nhJNZbnWeFIdARmH20-11">
          <mxGeometry x="15" y="40" width="350" height="320" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="L3nhJNZbnWeFIdARmH20-15" target="L3nhJNZbnWeFIdARmH20-20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-15" value="My Projects" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="980" width="380" height="700" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-16" value="Here are the major team projects I had done:&lt;br&gt;- flask-blog-secure&lt;br&gt;- vision-core&lt;br&gt;- lovelace&lt;br&gt;&amp;nbsp;&lt;br&gt;Here are the major personal projects I had done:&lt;br&gt;- GogoBot&lt;br&gt;- timer-plus&lt;br&gt;- django-store&lt;br&gt;- discord-bot&lt;br&gt;- SGJB-Traffic&lt;br&gt;- lecture-summariser&lt;br&gt;- career-meet&lt;br&gt;- the-solar-system&lt;br&gt;- python-vending-machine&lt;br&gt;&lt;br&gt;&lt;br&gt;Here are the rest of the projects you may be interested:&lt;br&gt;- boilerplates&lt;br&gt;- cli-utils&lt;br&gt;- ubersicht&lt;br&gt;- FxC&lt;br&gt;- DisplayFormPrototype&lt;br&gt;- MEE6-Grind&lt;br&gt;- days-till-bday&lt;br&gt;- defenders&lt;br&gt;- facebook&lt;br&gt;- flask-flutter-todo&lt;br&gt;- gform-bot&lt;br&gt;- ica-auto&lt;br&gt;- instabot-test&lt;br&gt;- mern-stack&lt;br&gt;- monkeytype-grind&lt;br&gt;- next-notes&lt;br&gt;- nyp-book-facility&lt;br&gt;- online-messenger&lt;br&gt;- repair-service-website&lt;br&gt;- sgjb-traffic-collection&lt;br&gt;- typing-test&lt;br&gt;- uxd-auto&lt;br&gt;- yb-pulse&lt;br&gt;- youtube-playlist-download&lt;br&gt;- youtube-playlist-to-videoId" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="L3nhJNZbnWeFIdARmH20-15">
          <mxGeometry x="15" y="40" width="350" height="650" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-26" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="L3nhJNZbnWeFIdARmH20-20" target="L3nhJNZbnWeFIdARmH20-24">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-20" value="My Certifications" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="1740" width="380" height="450" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-21" value="Here are my certifications for courses taken:&lt;br&gt;- Think Outside the Inbox: Email Marketing&lt;br&gt;- Using Python to Interact with the Operating System&lt;br&gt;- Project Initiation - Starting a Successful Project&lt;br&gt;- Operate and Manage a Cloud Server&lt;br&gt;- Foundations of Project Management&lt;br&gt;- Foundations of Digital Marketing and E-commerce&lt;br&gt;- Crash Course on Python&lt;br&gt;- Building RESTful APIs with Flask&lt;br&gt;- Unit Trusts and Investment - Linked Insurance Policy&lt;br&gt;- Foreign Exchange Margin Trading&lt;br&gt;- Contracts for Differences (CFDs)&lt;br&gt;- Literacy in AI&lt;br&gt;- Make the Sale - Build, Launch, and Manage Ecommerce Stores&lt;br&gt;- Assess for Success - Marketing Analytics and&amp;nbsp; Measurement&lt;br&gt;&lt;br&gt;Here are my certification for events I had participated:&lt;br&gt;- May CTF 2022&lt;br&gt;- Lag and Crash 2022&lt;br&gt;- Code Overflow 2022&lt;br&gt;-&amp;nbsp;V Hack 2023&lt;br&gt;&lt;br&gt;My next step will be pursuing AWS Certified Developer - Associate certificate.&lt;br&gt;&lt;br&gt;TO BE RECONFIRMED LATER" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="L3nhJNZbnWeFIdARmH20-20">
          <mxGeometry x="15" y="40" width="350" height="390" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-29" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="L3nhJNZbnWeFIdARmH20-24" target="L3nhJNZbnWeFIdARmH20-27">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-24" value="My Education" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="2230" width="380" height="130" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-25" value="I started my IT education journey from Nanyang Polytechnic, which is currently. Started from 2021 and will graduate at 2024.&lt;br&gt;&lt;br&gt;My next step will be pursuing a bachelor degree majoring in Software Engineering at SIT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="L3nhJNZbnWeFIdARmH20-24">
          <mxGeometry x="15" y="40" width="350" height="70" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-32" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="L3nhJNZbnWeFIdARmH20-27" target="L3nhJNZbnWeFIdARmH20-30">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-27" value="My Experiences" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="2390" width="380" height="240" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-28" value="I started my IT work journey from being a Digital Business Analyst Intern in Prime Minister Office, Strategy Group for 6 months. As my internship is controlled by Nanyang Polytechnic, I was not able to choose which role I want to work as, and which company I want to work in. However still, I had enjoyed being in this internship. I had learnt a lot while working here, for example working as a team, being proficient working with Microsoft 365 tools, and more.&lt;br&gt;&lt;br&gt;My next step will be to find a Software Engineering internship in Tech companies." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="L3nhJNZbnWeFIdARmH20-27">
          <mxGeometry x="15" y="40" width="350" height="180" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-30" value="Contact Me" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="2680" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="L3nhJNZbnWeFIdARmH20-31" value="You can contact me by filling in the form, or you can call me, email me, for through my social media platforms." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="L3nhJNZbnWeFIdARmH20-30">
